# modified Goovebox theme to use Dracula color scheme 

"$schema" = 'https://starship.rs/config-schema.json'

format = """
[¯éÂ](color_purple)\
$os\
$username\
[¯é░](bg:color_pink fg:color_purple)\
$directory\
[¯é░](fg:color_pink bg:color_cyan)\
$git_branch\
$git_status\
[¯é░](fg:color_cyan bg:color_green)\
$c\
$cpp\
$rust\
$golang\
$nodejs\
$php\
$java\
$kotlin\
$haskell\
$python\
[¯é░](fg:color_green bg:color_bg3)\
$docker_context\
$conda\
$pixi\
[¯é░](fg:color_bg3 bg:color_bg1)\
$time\
[¯é┤ ](fg:color_bg1)\
$line_break$character"""

palette = 'dracula_dark'

[palettes.dracula_dark]
color_fg0 = '#f8f8f2'
color_bg1 = '#6272a4'
color_bg3 = '#44475a'
color_cyan = '#8be9fd'
color_pink = '#ff79c6'
color_green = '#50fa7b'
color_orange = '#ffb86c'
color_purple = '#bd93f9'
color_red = '#ff5555'
color_yellow = '#f1fa8c'

[os]
disabled = false
style = "bg:color_purple fg:color_bg3"

[os.symbols]
Windows = "¾░ı▓"
Ubuntu = "¾░òê"
SUSE = "´îö"
Raspbian = "¾░É┐"
Mint = "¾░ú¡"
Macos = "¾░ÇÁ"
Manjaro = "´îÆ"
Linux = "¾░î¢"
Gentoo = "¾░ú¿"
Fedora = "¾░úø"
Alpine = "´îÇ"
Amazon = "´ë░"
Android = "¯£Ä"
AOSC = "´îü"
Arch = "¾░úç"
Artix = "¾░úç"
EndeavourOS = "´åù"
CentOS = "´îä"
Debian = "¾░úÜ"
Redhat = "¾▒äø"
RedHatEnterprise = "¾▒äø"
Pop = "´î¬"

[username]
show_always = true
style_user = "bg:color_purple fg:color_bg3"
style_root = "bg:color_purple fg:color_bg3"
format = '[ $user ]($style)'

[directory]
style = "fg:color_fg0 bg:color_pink"
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "ÔÇĞ/"

[directory.substitutions]
"Documents" = "¾░êÖ "
"Downloads" = "´ÇÖ "
"Music" = "¾░ØÜ "
"Pictures" = "´Ç¥ "
"Developer" = "¾░▓ï "

[git_branch]
symbol = "´Éİ"
style = "bg:color_cyan"
format = '[[ $symbol $branch ](fg:color_bg3 bg:color_cyan)]($style)'

[git_status]
style = "bg:color_cyan"
format = '[[($all_status$ahead_behind )](fg:color_bg3 bg:color_cyan)]($style)'

[nodejs]
symbol = "¯£İ"
style = "bg:color_green"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_green)]($style)'

[c]
symbol = "¯İŞ "
style = "bg:color_green"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_green)]($style)'

[cpp]
symbol = "¯İØ "
style = "bg:color_green"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_green)]($style)'

[rust]
symbol = "¯Ş¿"
style = "bg:color_green"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_green)]($style)'

[golang]
symbol = "¯İğ"
style = "bg:color_green"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_green)]($style)'

[php]
symbol = "¯İê"
style = "bg:color_green"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_green)]($style)'

[java]
symbol = "¯ëû"
style = "bg:color_green"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_green)]($style)'

[kotlin]
symbol = "¯İ┤"
style = "bg:color_green"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_green)]($style)'

[haskell]
symbol = "¯İş"
style = "bg:color_green"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_green)]($style)'

[python]
symbol = "¯İå"
style = "bg:color_green"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_green)]($style)'

[docker_context]
symbol = "´îê"
style = "bg:color_bg3"
format = '[[ $symbol( $context) ](fg:#83a598 bg:color_bg3)]($style)'

[conda]
style = "bg:color_bg3"
format = '[[ $symbol( $environment) ](fg:#83a598 bg:color_bg3)]($style)'

[pixi]
style = "bg:color_bg3"
format = '[[ $symbol( $version)( $environment) ](fg:color_fg0 bg:color_bg3)]($style)'

[time]
disabled = false
time_format = "%R"
style = "bg:color_bg1"
format = '[[ ´É║ $time ](fg:color_fg0 bg:color_bg1)]($style)'

[line_break]
disabled = false

[character]
disabled = false
success_symbol = '[´É▓](bold fg:color_green)'
error_symbol = '[´É▓](bold fg:color_red)'
vimcmd_symbol = '[´É┤](bold fg:color_green)'
vimcmd_replace_one_symbol = '[´É┤](bold fg:color_purple)'
vimcmd_replace_symbol = '[´É┤](bold fg:color_purple)'
vimcmd_visual_symbol = '[´É┤](bold fg:color_yellow)'
